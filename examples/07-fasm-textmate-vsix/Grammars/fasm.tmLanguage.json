{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "fasmg (.fasm/.finc)",
  "scopeName": "source.fasmg",
  "fileTypes": [
    "fasm",
    "finc"
  ],
  "patterns": [
    {
      "include": "#line"
    }
  ],
  "repository": {
    "line": {
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "#line-continuation"
        },
        {
          "include": "#calminstruction-block"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#label-definition"
        },
        {
          "include": "#preprocessor"
        },
        {
          "include": "#macro-definition-head"
        },
        {
          "include": "#control-directives"
        },
        {
          "include": "#data-directives"
        },
        {
          "include": "#storage-directives"
        },
        {
          "include": "#directives"
        },
        {
          "include": "#operators-word"
        },
        {
          "include": "#size-constants"
        },
        {
          "include": "#special-symbols"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#operators-punct"
        },
        {
          "include": "#identifiers"
        }
      ]
    },
    "comment": {
      "name": "comment.line.semicolon.fasmg",
      "begin": ";",
      "end": "$",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.fasmg"
        }
      }
    },
    "line-continuation": {
      "name": "constant.character.escape.continuation.fasmg",
      "match": "\\\\\\s*$"
    },
    "strings": {
      "patterns": [
        {
          "comment": "Single-quoted: doubled '' is the only escape; unclosed at EOL is an error.",
          "name": "string.quoted.single.fasmg",
          "begin": "'",
          "end": "(?:('(?!')))|(\\n|$)",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.fasmg"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.fasmg"
            },
            "2": {
              "name": "invalid.illegal.unclosed-string.fasmg"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.fasmg",
              "match": "''"
            }
          ]
        },
        {
          "comment": "Double-quoted: doubled \"\" is the only escape; unclosed at EOL is an error.",
          "name": "string.quoted.double.fasmg",
          "begin": "\"",
          "end": "(?:(\"(?!\")))|(\\n|$)",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.fasmg"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.fasmg"
            },
            "2": {
              "name": "invalid.illegal.unclosed-string.fasmg"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.fasmg",
              "match": "\"\""
            }
          ]
        }
      ]
    },
    "numbers": {
      "comment": "Aligned to the previously verified fasmg grammar work: lowercase 0x only, _ and ' separators, and float/exponent edge handling.",
      "patterns": [
        {
          "name": "constant.numeric.hex.fasmg",
          "match": "(?<![\\w.#])0x[0-9A-Fa-f_']+"
        },
        {
          "name": "constant.numeric.hex.fasmg",
          "match": "(?<![\\w.#])\\$[0-9A-Fa-f][0-9A-Fa-f_']*"
        },
        {
          "name": "constant.numeric.hex.fasmg",
          "match": "(?<![\\w.#])[0-9][0-9A-Fa-f_']*[hH]\\b"
        },
        {
          "name": "constant.numeric.binary.fasmg",
          "match": "(?<![\\w.#])[01][01_']*[bB]\\b"
        },
        {
          "name": "constant.numeric.octal.fasmg",
          "match": "(?<![\\w.#])[0-7][0-7_']*[oOqQ]\\b"
        },
        {
          "name": "constant.numeric.float.fasmg",
          "match": "(?<![\\w.#])[0-9][0-9_']*\\.[0-9][0-9_']*(?:(?:[eE][+-]?[0-9_']*[0-9][0-9_']*)|[fF])?\\b"
        },
        {
          "name": "constant.numeric.float.fasmg",
          "match": "(?<![\\w.#])[0-9][0-9_']*[eE][+-]?[0-9_']*[0-9][0-9_']*\\b"
        },
        {
          "name": "constant.numeric.float.fasmg",
          "match": "(?<![\\w.#])[0-9][0-9_']*[fF]\\b"
        },
        {
          "name": "constant.numeric.decimal.fasmg",
          "match": "(?<![\\w.#])[0-9][0-9_']*[dD]?\\b"
        }
      ]
    },
    "label-definition": {
      "match": "^\\s*([A-Za-z_.?#][\\w.?#]*)\\s*(::?)(?!=)",
      "captures": {
        "1": {
          "name": "entity.name.label.fasmg"
        },
        "2": {
          "name": "punctuation.separator.label.fasmg"
        }
      }
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.fasmg",
          "begin": "(?i)\\b(include)\\b(!)?",
          "end": "$",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.fasmg"
            },
            "2": {
              "name": "keyword.operator.unconditional.fasmg"
            }
          },
          "patterns": [
            {
              "include": "#comment"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#identifiers"
            }
          ]
        }
      ]
    },
    "macro-definition-head": {
      "match": "(?i)^\\s*(macro|struc)\\b(!)?\\s*(?:\\(\\s*([A-Za-z_?][\\w.?#]*)\\s*\\)\\s*)?([A-Za-z_.?#][\\w.?#]*)?",
      "captures": {
        "1": {
          "name": "storage.type.macro.fasmg"
        },
        "2": {
          "name": "keyword.operator.unconditional.fasmg"
        },
        "3": {
          "name": "variable.parameter.label.fasmg"
        },
        "4": {
          "name": "entity.name.function.macro.fasmg"
        }
      }
    },
    "control-directives": {
      "name": "keyword.control.fasmg",
      "match": "(?i)(?<![\\w.#])(?:if|else\\s+if|else\\s+match|else|end\\s+if|end\\s+match|end\\s+while|end\\s+repeat|end\\s+iterate|end\\s+irp|end\\s+irpv|end\\s+macro|end\\s+struc|end\\s+namespace|end\\s+virtual|end\\s+postpone|end|while|repeat|rept|iterate|irp|irpv|match|rawmatch|rmatch|postpone|break|continue|namespace|virtual|assert|outscope)(?![\\w.#?])"
    },
    "data-directives": {
      "name": "keyword.other.data.fasmg",
      "match": "(?i)(?<![\\w.#])(?:db|dw|dd|dp|dq|dt|ddq|dqq|ddqq|rb|rw|rd|rp|rq|rt|rdq|rqq|rdqq|emit|dbx|file|dup)(?![\\w.#?])"
    },
    "storage-directives": {
      "name": "storage.type.fasmg",
      "match": "(?i)(?<![\\w.#])(?:equ|reequ|define|redefine|label|element|restore|purge|restruc|mvmacro|mvstruc|esc|local)(?![\\w.#?])"
    },
    "directives": {
      "name": "keyword.other.directive.fasmg",
      "match": "(?i)(?<![\\w.#])(?:org|section|restartout|load|store|format|binary|executable|display|err|eval|retaincomments|removecomments|isolatelines|combinelines)(?![\\w.#?])"
    },
    "operators-word": {
      "name": "keyword.operator.word.fasmg",
      "match": "(?i)(?<![\\w.#])(?:mod|xor|and|or|not|shl|shr|bsf|bsr|bswap|string|lengthof|bappend|element|scale|metadata|elementof|scaleof|metadataof|elementsof|sizeof|float|trunc|eq|eqtype|relativeto|defined|definite|used|at|from|as)(?![\\w.#?])"
    },
    "size-constants": {
      "name": "support.constant.size.fasmg",
      "match": "(?i)(?<![\\w.#])(?:byte|word|dword|fword|pword|qword|tbyte|tword|dqword|xword|qqword|yword|dqqword|zword)\\??(?![\\w.#])"
    },
    "special-symbols": {
      "patterns": [
        {
          "name": "variable.language.address.fasmg",
          "match": "\\$(?:\\$|@|%%|%)?"
        },
        {
          "name": "variable.language.repeat-counter.fasmg",
          "match": "(?<![\\w.#])%%?(?![\\w.#])"
        },
        {
          "name": "support.constant.builtin.fasmg",
          "match": "(?<![\\w.#])__(?:time|file|line|source)__(?![\\w.#])"
        },
        {
          "name": "support.constant.builtin.fasmg",
          "match": "(?<![\\w.#])%t(?![\\w.#])"
        }
      ]
    },
    "operators-punct": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.fasmg",
          "match": ":=|=:|==|="
        },
        {
          "name": "keyword.operator.comparison.fasmg",
          "match": "<=|>=|<>|<|>"
        },
        {
          "name": "keyword.operator.logical.fasmg",
          "match": "[&|~]"
        },
        {
          "name": "keyword.operator.arithmetic.fasmg",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.context.fasmg",
          "match": "[`#]"
        },
        {
          "name": "punctuation.separator.fasmg",
          "match": "[,:]"
        },
        {
          "name": "punctuation.section.parens.fasmg",
          "match": "[()\\[\\]{}]"
        },
        {
          "name": "keyword.operator.modifier.fasmg",
          "match": "[!?]"
        }
      ]
    },
    "identifiers": {
      "comment": "A fasmg name is a maximal run of non-special, non-whitespace characters. Numbers are matched earlier, so digit-leading segments can still appear after a dot inside a compound name.",
      "patterns": [
        {
          "match": "\\??(?:[.]+)?[^\\s+\\-/*=<>()\\[\\]{}:?!,.|&~`;\\\\][^\\s+\\-/*=<>()\\[\\]{}:?!,.|&~`;\\\\]*\\??(?:[.#]+[^\\s+\\-/*=<>()\\[\\]{}:?!,.|&~`;\\\\]+\\??)*",
          "name": "variable.other.fasmg"
        }
      ]
    },
    "calminstruction-block": {
      "comment": "DSL within the language: calminstruction ... end calminstruction.",
      "begin": "(?i)^\\s*(calminstruction)\\b(!)?\\s*(?:\\(\\s*([A-Za-z_?][\\w.?#]*)\\s*\\)\\s*)?([A-Za-z_.?#][\\w.?#]*)?",
      "end": "(?i)^\\s*(end\\s+calminstruction)\\b",
      "beginCaptures": {
        "1": {
          "name": "storage.type.calminstruction.fasmg"
        },
        "2": {
          "name": "keyword.operator.unconditional.fasmg"
        },
        "3": {
          "name": "variable.parameter.label.fasmg"
        },
        "4": {
          "name": "entity.name.function.calminstruction.fasmg"
        }
      },
      "endCaptures": {
        "1": {
          "name": "storage.type.calminstruction.fasmg"
        }
      },
      "name": "meta.calminstruction.fasmg",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "#line-continuation"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#calm-label"
        },
        {
          "include": "#calm-commands"
        },
        {
          "include": "#calm-match-modifiers"
        },
        {
          "include": "#operators-word"
        },
        {
          "include": "#size-constants"
        },
        {
          "include": "#special-symbols"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#operators-punct"
        },
        {
          "include": "#identifiers"
        }
      ]
    },
    "calm-label": {
      "match": "^\\s*([A-Za-z_][\\w]*)\\s*(:)(?!=)",
      "captures": {
        "1": {
          "name": "entity.name.label.calm.fasmg"
        },
        "2": {
          "name": "punctuation.separator.label.fasmg"
        }
      }
    },
    "calm-commands": {
      "name": "keyword.control.calm.fasmg",
      "match": "(?i)(?<![\\w.#])(?:assemble|match|rawmatch|arrange|compute|check|publish|transform|stringify|take|taketext|call|local|jyes|jno|jump|exit|emit|display|err|load|store)(?![\\w.#?])"
    },
    "calm-match-modifiers": {
      "name": "support.type.calm-modifier.fasmg",
      "match": "(?i)(?<![\\w.#])(?:name|expression|number|quoted|equ|macro|struc|priorequ|priormacro|priorstruc|area)(?![\\w.#?])"
    }
  }
}
